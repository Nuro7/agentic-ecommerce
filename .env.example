# ────────────────────────────────────────────────────────────────────────
# Agentic Commerce — Environment variable template
#
# Copy this file to .env and fill in real values before running locally.
# NEVER commit .env to git. All secrets must come from environment or a
# secrets manager in production.
#
#   cp .env.example .env
# ────────────────────────────────────────────────────────────────────────

# ─── Application ────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# ─── Database (PostgreSQL) ───────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentic_commerce

# ─── Cache (Redis) ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Security ────────────────────────────────────────────────────────────
# JWT signing secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=change-me-generate-a-long-random-hex-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Field-level encryption key for stored platform credentials (Fernet):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-generate-a-fernet-key

# Shared secret between WordPress plugin and this backend:
#   python -c "import secrets; print(secrets.token_hex(32))"
SHARED_SECRET=change-me

# ─── LLM providers ───────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_STT_MODEL=whisper-large-v3-turbo
GROQ_MAX_TOOLS=2

OPENAI_API_KEY=

GEMINI_API_KEY=
GEMINI_VOICE=Aoede            # Multilingual voices: Aoede Charon Fenrir Kore Leda Orus Sulafat Zephyr

# LLM routing
AGENT_MODE=hybrid             # hybrid | groq | openai | gemini
GPT_MINI_TOOL_THRESHOLD=3
GEMINI_DRAVIDIAN_LANGS=ml,ta,te,kn

# ─── TTS / STT ───────────────────────────────────────────────────────────
STT_PROVIDER=groq             # groq | deepgram
TTS_PROVIDER=google           # google | elevenlabs | browser

# Google Cloud Text-to-Speech (free tier: 1M WaveNet chars/month)
# Enable at: console.cloud.google.com → Cloud Text-to-Speech API → Credentials
GOOGLE_TTS_API_KEY=

ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=

# ─── WooCommerce / WordPress (legacy — used by wooagent-backend) ─────────
WOOCOMMERCE_STORE_URL=http://localhost
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=
WOOCOMMERCE_AUTH_METHOD=auto
WOOCOMMERCE_ENABLE_WC_V3_FALLBACK=false

# ─── Shopify (Module 8) ──────────────────────────────────────────────────
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_SCOPES=read_products,read_orders,write_orders
SHOPIFY_APP_URL=https://your-app.example.com

# ─── Razorpay billing (Module 4) ─────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Tunnelling (local dev only) ─────────────────────────────────────────
NGROK_AUTHTOKEN=

# ─── Store branding (shown to the agent) ─────────────────────────────────
STORE_NAME=Your Store Name
STORE_CURRENCY=₹
STORE_ABOUT=We are an online store offering quality products at great prices.
STORE_SHIPPING_POLICY=Free delivery on orders above ₹499. Standard delivery in 3-5 business days.
STORE_RETURNS_POLICY=Easy 7-day returns. No questions asked on unused items.
STORE_PAYMENT_METHODS=UPI, Credit/Debit Card, Net Banking, Cash on Delivery

# ─── Feature flags ───────────────────────────────────────────────────────
MVP_MODE=true                 # true = skip billing/tier enforcement
MOCK_SERVICES=false           # true = use in-memory fakes for external APIs
BETA_LOGGING_ENABLED=false    # true = persist session transcripts to DB
