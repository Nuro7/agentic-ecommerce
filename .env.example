# Application
APP_NAME=Agentic Commerce
ENVIRONMENT=dev
DEBUG=true
LOG_LEVEL=INFO

# Supabase Database
# Get both URLs from: Supabase Dashboard -> Project Settings -> Database
# DATABASE_URL: pooled connection (port 6543, "Transaction" mode) - used by app runtime
# DATABASE_DIRECT_URL: direct connection (port 5432) - used by Alembic migrations
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres
DATABASE_DIRECT_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=2

# Redis (local in Docker)
REDIS_URL=redis://localhost:6379/0

# Security (placeholder — real values added in Module 3)
JWT_SECRET_KEY=change-me-in-production-this-is-just-for-dev

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# External services (placeholders — real values added in later modules)
GEMINI_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
