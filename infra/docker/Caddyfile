# Speako reverse proxy + automatic HTTPS.
# The domain comes from the DOMAIN environment variable (set in the root .env),
# NOT hardcoded here — so CI/CD's `git reset --hard` never clobbers it and the
# same file works on any host. Caddy fetches a free Let's Encrypt cert for
# whatever DOMAIN resolves to this server (ports 80/443 must be open).

{$DOMAIN} {
    reverse_proxy web:8000
}
