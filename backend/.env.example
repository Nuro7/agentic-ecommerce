# Application
APP_NAME=Agentic Commerce
ENVIRONMENT=dev
DEBUG=true
LOG_LEVEL=INFO

# PostgreSQL
# When running via docker-compose, the app container overrides these to use the
# 'postgres' service hostname. These values are used when running the app locally
# outside Docker (e.g. alembic migrations from the host machine).
DATABASE_URL=postgresql+asyncpg://agentic:agentic@localhost:5432/agentic_commerce
DATABASE_DIRECT_URL=postgresql+asyncpg://agentic:agentic@localhost:5432/agentic_commerce
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=2

# Redis (local in Docker)
REDIS_URL=redis://localhost:6379/0

# Security (placeholder — real values added in Module 3)
JWT_SECRET_KEY=change-me-in-production-this-is-just-for-dev

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# External services
GEMINI_API_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── AI / LLM keys (app/ backend) ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
# GEMINI_API_KEY set above — used for both Gemini Live WebSocket and Gemini Flash LLM

# ── TTS / STT (app/ backend) ──────────────────────────────────────────────────
GOOGLE_TTS_API_KEY=
ELEVENLABS_API_KEY=
# TTS_PROVIDER: google (default) | elevenlabs | groq | browser
TTS_PROVIDER=google

# ── Ngrok tunnel (for WordPress webhook from local dev) ───────────────────────
NGROK_AUTHTOKEN=

# ── WooAgent backend (wooagent-backend/) ──────────────────────────────────────
# Platform selector: "woocommerce" (default) or "shopify"
PLATFORM=woocommerce

# WooCommerce (used when PLATFORM=woocommerce)
WOOCOMMERCE_STORE_URL=https://yourstore.com
WOOCOMMERCE_CONSUMER_KEY=ck_xxx
WOOCOMMERCE_CONSUMER_SECRET=cs_xxx
SHARED_SECRET=change-me

# Shopify (used when PLATFORM=shopify)
SHOPIFY_STORE_DOMAIN=yourstore.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token
SHOPIFY_ADMIN_TOKEN=shpat_your_admin_token
SHOPIFY_API_VERSION=2024-01

# Shared store settings
STORE_NAME=My Store
STORE_CURRENCY=$

# Shopify widget appearance (used by /shopify/widget-loader.js)
# Add your Shopify store domain to ALLOWED_ORIGINS for CORS when PLATFORM=shopify
# e.g. ALLOWED_ORIGINS=https://yourstore.myshopify.com,https://yourstore.com
ALLOWED_ORIGINS=*
SHOPIFY_WIDGET_COLOR=#6366f1
SHOPIFY_WIDGET_POSITION=bottom-right
SHOPIFY_GREETING=Hi! I'm Aria, your shopping assistant. Ask me anything!
SHOPIFY_ENABLE_VOICE=true
SHOPIFY_ENABLE_TEXT=true
SHOPIFY_LANGUAGE=en

# Public backend URL (auto-detected from request headers if omitted; set explicitly for ngrok/CDN)
# BACKEND_URL=https://abc123.ngrok.io
